{
  "name": "hello_solana_dapp",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "anchor-tstest": "cd anchor && anchor run tstest",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "npm run codama:vault && npm run codama:favorites",
    "codama:vault": "codama -i ./anchor/target/idl/vault.json run vault",
    "codama:favorites": "codama -i ./anchor/target/idl/favorites.json run favorites",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "setup": "npm run anchor-build && npm run codama:js",
    "start": "next start"
  },
  "description": "Next.js, Tailwind, @solana/kit, Anchor vault program",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@solana/kit": "^6.3.0",
    "@solana/kit-client-rpc": "^0.7.0",
    "@solana/kit-plugin-rpc": "^0.7.0",
    "@solana/wallet-standard-features": "^1.3.0",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "swr": "^2.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.0.1",
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/postcss": "^4",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^6.2.2",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "ts-mocha": "^11.1.0",
    "typescript": "^5"
  }
}
